{
  "name": "@dowant/lionscraper",
  "version": "1.0.0",
  "description": "LionScraper bridge daemon, thin MCP stdio, and CLI — local HTTP + WebSocket to Chrome extension",
  "type": "module",
  "main": "dist/mcp.js",
  "bin": {
    "lionscraper": "dist/lionscraper.js",
    "lionscraper-mcp": "dist/mcp.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/lionscraper.js daemon",
    "stop": "node dist/lionscraper.js stop",
    "restart": "npm run stop && npm run start",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "lionscraper",
    "web-scraping",
    "chrome-extension"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ws": "^8.18.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
